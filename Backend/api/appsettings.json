{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [
    "https://your-production-domain.com"
  ],
  "ConnectionStrings": {
    "SqlServer": "REPLACE_IN_ENV_OR_USER_SECRETS",
    "Postgres": "REPLACE_IN_ENV_OR_USER_SECRETS",
    "VectorDb": "REPLACE_IN_ENV_OR_USER_SECRETS"
  },
  "JwtOptions": {
    "SecretKey": "REPLACE_IN_ENV_OR_USER_SECRETS",
    "Issuer": "api",
    "Audience": "api-client",
    "ExpiryMinutes": 60
  },
  "OllamaOptions": {
    "BaseUrl": "http://localhost:11434",
    "EmbeddingModel": "nomic-embed-text",
    "ChatModel": "llama3.2"
  },
  "Chunking": {
    "ChunkSize": 600,
    "ChunkOverlap": 100,
    "TopK": 8,
    "SimilarityThreshold": 0.2
  }
}